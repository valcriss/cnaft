# Development
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cnaft?schema=public"
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
CORS_ORIGIN="*"

# Auth mode
AUTH_PROVIDER="local" # local|oidc
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_TRANSPARENT_LOGIN="true"
OIDC_CA_CERT_PATH=""
OIDC_TLS_INSECURE="false"
